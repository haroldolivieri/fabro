ANTHROPIC_API_KEY=
BRAVE_SEARCH_API_KEY=
DAYTONA_API_KEY=
GEMINI_API_KEY=
INCEPTION_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
OPENAI_API_KEY=
ZAI_API_KEY=

FABRO_JWT_PRIVATE_KEY=
FABRO_JWT_PUBLIC_KEY=

SESSION_SECRET=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_PRIVATE_KEY=

FABRO_SLACK_APP_TOKEN=
FABRO_SLACK_BOT_TOKEN=

# Public hostname for the prod docker-compose stack. Leave unset for
# localhost (Caddy will serve plain HTTP); set to a real DNS name to
# let Caddy auto-provision a Let's Encrypt certificate.
FABRO_DOMAIN=

# Portkey AI gateway (optional — routes LLM traffic through Portkey when set)
# Docs: https://fabro.sh/docs/integrations/portkey
PORTKEY_URL=
PORTKEY_API_KEY=
PORTKEY_PROVIDER=

# Optional Portkey settings:
# PORTKEY_PROVIDER_SLUG=         # Override x-portkey-provider header (e.g. @bedrock-sandbox)
# PORTKEY_CONFIG=                # Portkey config ID or inline JSON
# PORTKEY_METADATA=              # JSON metadata for observability

# Direct AWS Bedrock credentials (alternative to Portkey Model Catalog):
# PORTKEY_AWS_ACCESS_KEY_ID=
# PORTKEY_AWS_SECRET_ACCESS_KEY=
# PORTKEY_AWS_REGION=
# PORTKEY_AWS_SESSION_TOKEN=