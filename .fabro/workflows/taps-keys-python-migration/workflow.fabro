digraph TapsKeys {
    graph [
        goal="Build and publish a byte-for-byte compatible Python taps-keys library, validated against golden fixtures from the Java source of truth.",
        model_stylesheet="* { model: eu.anthropic.claude-sonnet-4-6; }",
        stall_timeout="3600s"
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare,  label="Done"]

    // ── Setup ────────────────────────────────────────────────────────────

    setup [
        label="Setup:\nclone + fixtures",
        shape=parallelogram,
        script="echo '=== Cloning repos (fixtures + schemas only) ==='\nif [ -d taps-keys-fixtures ]; then (cd taps-keys-fixtures && git checkout -- . 2>/dev/null; git pull 2>/dev/null || true); else git clone git@github.com:Skyscanner/taps-keys-fixtures.git; fi\nif [ -d taps-keys-schemas ]; then (cd taps-keys-schemas && git checkout -- . 2>/dev/null; git pull 2>/dev/null || true); else git clone git@github.com:Skyscanner/taps-keys-schemas.git; fi\necho '=== Running fixture generator ==='\ncd tools/taps-keys-fixture-gen && ./gradlew run 2>&1 || { echo 'FATAL: fixture generator failed'; exit 1; }\nENCS=$(jq length golden_encodings.json) && SIGS=$(jq length golden_signatures.json)\necho \"fixtures: $ENCS encodings, $SIGS signatures\"\n[ \"$ENCS\" -gt 0 ] && [ \"$SIGS\" -gt 0 ] && [ \"$ENCS\" -eq $((SIGS * 11)) ] || { echo 'FATAL: fixture count mismatch'; exit 1; }\nmkdir -p /tmp/taps-keys-fixtures\ncp golden_encodings.json golden_signatures.json /tmp/taps-keys-fixtures/\nrm -f golden_*.json\necho '=== Setup complete ==='",
        max_retries=0
    ]

    // ── Phase 1: Fixtures ────────────────────────────────────────────────

    build_fixtures [
        label="Build fixtures repo\n(runner + harness)",
        prompt="@prompts/fixtures-build.md",
        thread_id="fixtures", fidelity=full,
        max_visits=4
    ]

    validate_fixtures [
        label="Validate fixtures\n(self-test + build)",
        shape=parallelogram,
        script="cd taps-keys-fixtures && python3 -m pytest tests/ -v 2>&1 && python3 -m build 2>&1 && echo 'Fixtures: ALL CHECKS PASSED'",
        goal_gate=true,
        retry_target="fix_fixtures"
    ]

    fix_fixtures [
        label="Fix fixtures errors",
        prompt="The fixtures validation failed. Read the error output and fix the issues in taps-keys-fixtures/.\n\nSCOPE: Only modify files inside taps-keys-fixtures/.\n\nPROHIBITED: Do not modify the golden fixture JSON files. Fix the runner, tests, or harness.",
        thread_id="fixtures", fidelity=full,
        max_visits=3
    ]

    validate_fixtures_java [
        label="L4: Java binary\nvs fixture JSON",
        shape=parallelogram,
        script="cd tools/taps-keys-fixture-gen && ./gradlew validateFixtures 2>&1 || { echo 'FATAL: L4 fixture validation failed — fixture JSON does not match Java library output'; exit 1; }\necho 'L4: All fixture JSON values verified against production Java library'",
        goal_gate=true,
        retry_target="fix_fixture_generator"
    ]

    fix_fixture_generator [
        label="Fix FixtureGenerator\n(L4 mismatch)",
        prompt="The Java L4 validation found that golden_encodings.json contains incorrect expected values — the stored fields do not match what the production taps-keys Java library produces when called with the stored input values.\n\nRead the L4 error output carefully. Then read tools/taps-keys-fixture-gen/src/main/java/net/skyscanner/tools/FixtureGenerator.java and fix the bug.\n\nCommon causes:\n- Wrong field serialised (e.g. toString output stored in encoded_key slot)\n- Wrong input values passed to buildKey() vs what was stored in the entry\n- Incorrect wildcard handling in buildKeyWithWildcard()\n- Schema reflection lookup returning wrong schema\n\nSCOPE: Only modify tools/taps-keys-fixture-gen/src/main/java/net/skyscanner/tools/FixtureGenerator.java\n\nPROHIBITED: Do not modify ValidateFixtures.java — that is the ground truth validator.",
        thread_id="fixtures", fidelity=full,
        max_visits=3
    ]

    publish_fixtures [
        label="PR + install\ntaps-keys-fixtures",
        shape=parallelogram,
        script="cd taps-keys-fixtures && BRANCH=fabro/golden-fixtures-and-contract-runner && (git checkout -b $BRANCH 2>/dev/null || git checkout $BRANCH); rm -f golden_*.json java_outputs.json 2>/dev/null; rm -rf *.egg-info dist 2>/dev/null; git add . && git commit -m 'feat: golden fixtures + contract runner' --allow-empty 2>&1 && git push -u origin $BRANCH 2>&1 && (gh pr list --head $BRANCH --state open 2>&1 | grep -q . || gh pr create --title 'feat: golden fixtures and contract test runner' --body \"## Summary\n\nAdds the golden fixture dataset and a 3-layer contract test runner for validating any Python implementation of the TAPS keys encoding library against the Java reference.\n\n### What is included\n\n- **golden_encodings.json** — 710 encoding test cases (142 schemas x 5 input sets A-E) generated from the Java taps-keys library. Each entry contains the schema name, input values, expected base-32 encoded key, toString output, encoded length, and open-jaw filter result.\n- **golden_signatures.json** — 142 signature entries (one per schema) with 6 disjoint boolean properties each, capturing which components are absent from each schema.\n- **Contract test runner** (taps_keys_fixtures.runner) with 3 validation layers:\n  - **L1 Encoding** — byte-for-byte comparison of encoded keys and toString output against golden values\n  - **L2 Signatures** — validates schema signature() and disjoint properties against golden booleans\n  - **L3 Structural** — validates toString format, pipe-delimited toString, encodedLength, and OpenJawFilter derivation\n- **Error formatter** — intentionally restrictive output that never reveals full expected values (max 4-char prefix) to prevent lookup-table implementations\n- **Self-tests** (pytest) verifying fixture loading, runner infrastructure, and error formatter constraints\n- **Repo harness** — pyproject.toml, Makefile, CLAUDE.md, README\n\n### Usage\n\n\`\`\`bash\npip install -e .\npython -m taps_keys_fixtures.runner.test_runner --module taps_keys\npython -m taps_keys_fixtures.runner.test_runner --module taps_keys --layers L1\n\`\`\`\n\n### Context\n\nThis is Phase 1 of the taps-keys Python migration. The fixtures package is consumed by Phase 3 (taps-keys-python) to validate encoding correctness without the Python library ever seeing the raw fixture data directly.\" --head $BRANCH 2>&1) && python3 -m pip install -e . 2>&1 && echo 'Fixtures PR created + installed locally OK'"
    ]

    // ── Phase 2: Schemas ─────────────────────────────────────────────────

    build_schemas [
        label="Build schemas repo\n(extract + validate + harness)",
        prompt="@prompts/schemas-build.md",
        thread_id="schemas", fidelity=full,
        max_visits=4
    ]

    validate_schemas [
        label="Validate schemas\n(structural + fixture xref)",
        shape=parallelogram,
        script="cd taps-keys-schemas && python3 scripts/validate.py --fixtures-dir /tmp/taps-keys-fixtures 2>&1 && python3 -m build 2>&1 && echo 'Schemas: ALL CHECKS PASSED'",
        goal_gate=true,
        retry_target="fix_schemas"
    ]

    fix_schemas [
        label="Fix schemas errors",
        prompt="The schemas validation failed. Read the error output and fix the issues in taps-keys-schemas/. Focus on the first failing check only.\n\nSCOPE: Only modify files inside taps-keys-schemas/. Do not touch taps-keys-fixtures/ or taps-keys-python/.\n\nPROHIBITED: Do not modify scripts/validate.py or schemas.schema.json. Fix schemas.json or the harness files.",
        thread_id="schemas", fidelity=full,
        max_visits=3
    ]

    publish_schemas [
        label="PR + install\ntaps-keys-schemas",
        shape=parallelogram,
        script="cd taps-keys-schemas && BRANCH=fabro/schema-definitions-and-validation && (git checkout -b $BRANCH 2>/dev/null || git checkout $BRANCH); rm -f golden_*.json java_outputs.json 2>/dev/null; rm -rf *.egg-info dist 2>/dev/null; git add . && git commit -m 'feat: schemas.json + validation + Claude Code harness' --allow-empty 2>&1 && git push -u origin $BRANCH 2>&1 && (gh pr list --head $BRANCH --state open 2>&1 | grep -q . || gh pr create --title 'feat: schema definitions, validation, and Claude Code harness' --body \"## Summary\n\nExtracts all 142 key schema definitions (71 one-way, 71 return) from the Java taps-keys library into a language-neutral schemas.json, with structural validation and a full repo harness.\n\n### What is included\n\n- **schemas.json** — all 142 schema definitions extracted from Keys.java. Each schema contains:\n  - Ordered component list (type, name, bits, encoded_length)\n  - Derived toString (FCP file store name format)\n  - Derived encoded_length (sum of component widths)\n  - Derived OpenJawFilter (BOTH/ORIGIN/DESTINATION/NONE based on AIRPORT component presence)\n- **schemas.schema.json** — JSON Schema for validating schemas.json structure\n- **scripts/validate.py** — 13-check validation script covering:\n  - Checks 1-7: Structural (JSON Schema conformance, schema count = 142, valid component types, no duplicates, toString derivation, encoded_length consistency, OpenJawFilter derivation)\n  - Checks 8-12: Cross-reference against golden fixtures (bidirectional coverage, 5 input sets per schema, toString match, disjoint consistency)\n  - Check 13: Valid JSON structure in all fixture files\n- **Claude Code harness** — CLAUDE.md constitution, add-schema skill (.claude/agents/add-schema.md), Makefile, pyproject.toml, README, CONTRIBUTING\n\n### Why this repo exists\n\nBoth Java and Python pipelines must produce byte-for-byte identical keys. A shared schema definition prevents silent drift — schemas live in one place and both libraries are downstream consumers. The 13 structural checks make it impossible to add a schema that is internally inconsistent or missing from fixtures.\n\n### Context\n\nThis is Phase 2 of the taps-keys Python migration. The schemas package is consumed at runtime by Phase 3 (taps-keys-python) via importlib.resources — the Python library never bundles its own copy of schemas.json.\" --head $BRANCH 2>&1) && python3 -m pip install -e . 2>&1 && echo 'Schemas PR created + installed locally OK'"
    ]

    // ── Phase 3: Python Library ──────────────────────────────────────────

    setup_python [
        label="Setup Python repo\n(clone + schemas only)",
        shape=parallelogram,
        script="echo '=== Cloning taps-keys-python ==='\nif [ -d taps-keys-python ]; then (cd taps-keys-python && git checkout -- . 2>/dev/null; git pull 2>/dev/null || true); else git clone git@github.com:Skyscanner/taps-keys-python.git; fi\necho '=== Installing schemas from local repo (NO fixtures) ==='\npython3 -m pip install -e ./taps-keys-schemas 2>&1\npython3 -c 'from importlib.resources import files; print(\"schemas.json:\", len(files(\"taps_keys_schemas\").joinpath(\"schemas.json\").read_text()), \"bytes\")'\necho '=== Python setup complete (fixtures NOT installed) ==='"
    ]

    build_python [
        label="Build Python library\n(encoding + harness)",
        prompt="@prompts/python-build.md",
        thread_id="python", fidelity=full,
        max_visits=6
    ]

    validate_python [
        label="Validate Python\n(runner + pytest)",
        shape=parallelogram,
        script="echo '=== Installing fixtures from local repo for validation ==='\npython3 -m pip install -e ./taps-keys-fixtures 2>&1\necho '=== Running contract runner (all layers) ==='\ncd taps-keys-python && python3 -m taps_keys_fixtures.runner --module taps_keys 2>&1\necho '=== Running pytest ==='\npython3 -m pytest tests/ -v 2>&1\necho 'Python: ALL CHECKS PASSED'",
        goal_gate=true,
        retry_target="fix_python"
    ]

    fix_python [
        label="Fix Python errors",
        prompt="The Python validation failed. Read the output and fix the issues in taps-keys-python/. If contract runner failed, fix encoding. If pytest failed, fix tests.\n\nSCOPE: Only modify files inside taps-keys-python/.\n\nPROHIBITED: Do not read fixture files. Do not modify scripts/validate.py to weaken checks. Fix the implementation based on error descriptions only.",
        thread_id="python", fidelity=full,
        max_visits=5
    ]

    validate_java_parity [
        label="L5: Java binary\nvs Python direct",
        shape=parallelogram,
        script="echo '=== L5: Generating live Java outputs ==='\n(cd tools/taps-keys-fixture-gen && ./gradlew encodeMain 2>&1) || { echo 'FATAL: Java encoder failed'; exit 1; }\necho '=== L5: Comparing Python vs Java ==='\ncd taps-keys-python && PYTHONPATH=src python3 - <<'EOF'\nimport json, sys\nfrom datetime import datetime\nfrom taps_keys.keys import OneWay, Return\nfrom taps_keys.schema import KeyBuilder\n\nfixtures = json.load(open('/tmp/taps-keys-fixtures/golden_encodings.json'))\njava_out = {(e['schema'], e['input_set']): e for e in json.load(open('/tmp/java_outputs.json'))}\n\ndef get_schema(prefix, name):\n    return getattr(OneWay if prefix == 'oneway' else Return, name)\n\npassed = failed = 0\nfor entry in fixtures:\n    schema = get_schema(entry['prefix'], entry['schema'])\n    outbound = datetime.strptime(entry['outbound_date'], '%Y-%m-%d').date()\n    inbound = datetime.strptime(entry['inbound_date'], '%Y-%m-%d').date() if entry['inbound_date'] else None\n    b = (schema.key_builder()\n        .marketing_carrier(entry['carrier'])\n        .origin_airport(entry['origin']).origin_city(entry['origin']).origin_country(entry['origin'])\n        .destination_airport(entry['destination']).destination_city(entry['destination']).destination_country(entry['destination'])\n        .outbound_departure_year_month(outbound).outbound_departure_day(outbound))\n    if inbound:\n        b = b.inbound_departure_year_month(inbound).inbound_departure_day(inbound)\n    is_d = entry['is_direct']\n    b = b.is_direct(KeyBuilder.any_direct() if is_d == 'wildcard' else is_d)\n    key = b.build()\n    jk = (entry['schema'], entry['input_set'])\n    if jk not in java_out:\n        print(f\"FAIL [{entry['schema']}/{entry['input_set']}]: missing from Java output\")\n        failed += 1\n        continue\n    jv = java_out[jk]\n    if key.encode() == jv['encoded_key'] and key.to_string() == jv['to_string'] and key.to_string('|') == jv['to_string_pipe']:\n        passed += 1\n    else:\n        print(f\"FAIL [{entry['schema']}/{entry['input_set']}]: Python encode={key.encode()!r} Java={jv['encoded_key']!r}; toString={key.to_string()!r} Java={jv['to_string']!r}; toStringPipe={key.to_string('|')!r} Java={jv['to_string_pipe']!r}\")\n        failed += 1\nprint(f'L5: {passed}/{passed+failed} Java/Python parity checks passed')\nif failed > 0:\n    sys.exit(1)\nEOF",
        goal_gate=true,
        retry_target="fix_python"
    ]

    validate_fuzz_parity [
        label="L6: Fuzz\n14200 random inputs",
        shape=parallelogram,
        script="echo '=== L6: Generating 14200 fuzz inputs with Java (seed=42) ==='\n(cd tools/taps-keys-fixture-gen && ./gradlew fuzzEncode 2>&1) || { echo 'FATAL: Fuzz encoder failed'; exit 1; }\necho '=== L6: Comparing Python vs Java on fuzz inputs ==='\ncd taps-keys-python && PYTHONPATH=src python3 - <<'FUZZ'\nimport json, sys\nfrom datetime import datetime\nfrom taps_keys.keys import OneWay, Return\nfrom taps_keys.schema import KeyBuilder\n\nfuzz = json.load(open('/tmp/fuzz_java_outputs.json'))\n\ndef get_schema(prefix, name):\n    return getattr(OneWay if prefix == 'oneway' else Return, name)\n\npassed = failed = 0\nfor entry in fuzz:\n    try:\n        schema = get_schema(entry['prefix'], entry['schema'])\n        outbound = datetime.strptime(entry['outbound_date'], '%Y-%m-%d').date()\n        inbound = datetime.strptime(entry['inbound_date'], '%Y-%m-%d').date() if entry['inbound_date'] else None\n        b = (schema.key_builder()\n            .marketing_carrier(entry['carrier'])\n            .origin_airport(entry['origin']).origin_city(entry['origin']).origin_country(entry['origin'])\n            .destination_airport(entry['destination']).destination_city(entry['destination']).destination_country(entry['destination'])\n            .outbound_departure_year_month(outbound).outbound_departure_day(outbound))\n        if inbound:\n            b = b.inbound_departure_year_month(inbound).inbound_departure_day(inbound)\n        b = b.is_direct(entry['is_direct'])\n        key = b.build()\n        if key.encode() == entry['encoded_key'] and key.to_string() == entry['to_string'] and key.to_string('|') == entry['to_string_pipe']:\n            passed += 1\n        else:\n            print(f'FAIL [{entry[\"schema\"]}/fuzz-{entry[\"fuzz_id\"]}]: encode={key.encode()!r} Java={entry[\"encoded_key\"]!r}')\n            failed += 1\n    except Exception as e:\n        print(f'FAIL [{entry[\"schema\"]}/fuzz-{entry[\"fuzz_id\"]}]: {type(e).__name__}: {e}')\n        failed += 1\nprint(f'L6: {passed}/{passed+failed} fuzz parity checks passed')\nif failed > 0:\n    sys.exit(1)\nFUZZ",
        goal_gate=true,
        retry_target="fix_python"
    ]

    publish_python [
        label="PR + e2e verify",
        shape=parallelogram,
        script="cd taps-keys-python && BRANCH=fabro/python-taps-keys-encoding-library && (git checkout -b $BRANCH 2>/dev/null || git checkout $BRANCH); rm -f golden_*.json java_outputs.json 2>/dev/null; rm -rf *.egg-info dist 2>/dev/null; git add . && git commit -m 'feat: Python taps-keys encoding library' --allow-empty 2>&1 && git push -u origin $BRANCH 2>&1 && (gh pr list --head $BRANCH --state open 2>&1 | grep -q . || gh pr create --title 'feat: Python taps-keys encoding library' --body \"## Summary\n\nPython implementation of Skyscanner's taps-keys encoding library, producing byte-for-byte identical base-32 encoded keys to the Java reference implementation. These keys are used as lookup keys in the File Cache Proxy (FCP) for aggregated flight pricing data.\n\n### What is included\n\n- **Core encoding library** (src/taps_keys/):\n  - encoding.py — base-32 encoder with the custom alphabet (0-9a-v), per-component-type encoders with range validation\n  - schema.py — KeySchema, KeyBuilder (fluent API), Key, ComponentType enum, OpenJawFilter enum\n  - keys.py — OneWay and Return namespaces exposing all 142 KeySchema constants loaded from taps-keys-schemas\n  - website_id.py — fixed-32 encoding for Spark partitioning\n- **Unit tests** (tests/):\n  - test_encoding.py — base-32 boundary values, carrier offset encoding, YEARMONTH overflow (value 1024 -> 3 chars)\n  - test_schema.py — builder ignores extra fields, wildcard trailing enforcement, KeySchema picklability (PySpark), toString format\n  - test_website_id.py — fixed-32 encoding correctness\n- **Validation script** (scripts/validate.py) — delegates to the taps-keys-fixtures contract runner (L1-L3) + pytest\n- **Repo harness** — pyproject.toml, Makefile, CLAUDE.md, README, CONTRIBUTING, sync-schemas skill\n\n### Design decisions\n\n- **Schemas loaded at runtime** from taps-keys-schemas package via importlib.resources — no bundled copy\n- **KeySchema is picklable** — required for PySpark UDF serialisation\n- **KeyBuilder stores all setter values** keyed by (ComponentType, name) tuples; at build() time only the schema's components are looked up, extras are silently ignored\n- **Wildcard support** — trailing wildcards for DIRECT component (Set E), encode() stops at first wildcard, to_string() shows '*'\n- **YEARMONTH overflow** — value 1024 produces 3 chars ('100') matching Java's padStart-without-truncate behaviour\n\n### Validation\n\nPassed all 4 validation layers:\n- **L1** — 710/710 encoding test cases byte-for-byte identical to Java golden fixtures\n- **L2** — 852/852 signature and disjoint property checks match golden values\n- **L3** — toString, pipe-delimited toString, encodedLength, OpenJawFilter all match\n- **L4** — 710/710 fixture values verified against production Java library\n- **L5** — 710/710 Java/Python direct parity checks passed\n- **Unit tests** — all pytest tests pass\n\n### Context\n\nThis is Phase 3 (final) of the taps-keys Python migration. Depends on taps-keys-schemas (runtime) and taps-keys-fixtures (validation only, not a build dependency).\" --head $BRANCH 2>&1) && python3 -m pip install -e . 2>&1 && python3 -c \"\nfrom taps_keys.keys import OneWay\nfrom datetime import date\nkey = (OneWay.AIRPORT_AIRPORT_DAY_OW.key_builder()\n    .origin_airport(13554).destination_airport(13555)\n    .outbound_departure_year_month(date(2018,7,8))\n    .outbound_departure_day(date(2018,7,8))\n    .is_direct(True).build().encode())\nassert key == '0d7i0d7ji681', f'Got: {key}'\nprint('e2e OK:', key)\n\""
    ]

    // ── Edges ────────────────────────────────────────────────────────────

    start -> setup -> build_fixtures

    // Phase 1: fixtures → validate → L4 Java gate → PR
    build_fixtures         -> validate_fixtures
    validate_fixtures      -> validate_fixtures_java  [condition="outcome=success"]
    validate_fixtures      -> fix_fixtures
    fix_fixtures           -> validate_fixtures
    validate_fixtures_java -> publish_fixtures         [condition="outcome=success"]
    validate_fixtures_java -> fix_fixture_generator
    fix_fixture_generator  -> setup

    // Phase 2: schemas → validate → PR
    publish_fixtures  -> build_schemas
    build_schemas     -> validate_schemas
    validate_schemas  -> publish_schemas     [condition="outcome=success"]
    validate_schemas  -> fix_schemas
    fix_schemas       -> validate_schemas

    // Phase 3: python → validate → L5 Java parity gate → PR
    publish_schemas      -> setup_python
    setup_python         -> build_python
    build_python         -> validate_python
    validate_python      -> validate_java_parity  [condition="outcome=success"]
    validate_python      -> fix_python
    fix_python           -> validate_python
    validate_java_parity -> validate_fuzz_parity    [condition="outcome=success"]
    validate_java_parity -> fix_python
    validate_fuzz_parity -> publish_python          [condition="outcome=success"]
    validate_fuzz_parity -> fix_python

    publish_python    -> exit
}
