target
.env
.entire
node_modules
apps/fabro-web/dist/
lib/crates/fabro-spa/assets/*
!lib/crates/fabro-spa/assets/.gitkeep
tmp
evals/swe-bench/repos/
evals/swe-bench/results/
evals/swe-bench/dockerfiles/
__pycache__
.ai/plans
.ai/comments
.ai/tmp
.worktrees/
**/*.pending-snap
.worktrees
