.claude/scheduled_tasks.lock
.mcp.json
docs/internal/agent

# Never commit pre-built JARs — internal Skyscanner bytecode must not be in a public repo
tools/**/*.jar

# Gradle build artifacts
tools/**/.gradle/
tools/**/build/

# taps-keys output repos (generated by workflows)
taps-keys-schemas/
taps-keys-fixtures/
taps-keys-python/
