+    fn make_config(wt_path: &str) -> WorktreeConfig {
+        WorktreeConfig {
+            branch_name: "fabro/run/test-branch".to_string(),
+            base_sha: "abc123def456".to_string(),
+            worktree_path: wt_path.to_string(),
+            skip_branch_creation: false,
+        }
