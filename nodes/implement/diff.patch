+fn build_segment_batch(content: &str) -> Option<serde_json::Value> {
+    let mut batch = Vec::new();
+    for line in content.lines() {
+        let line = line.trim();
+        if line.is_empty() {
+            continue;
+        }
+        match serde_json::from_str::<serde_json::Value>(line) {
+            Ok(mut obj) => {
