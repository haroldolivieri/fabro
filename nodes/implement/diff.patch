-    async fn update_issue_state(&self, issue: &Issue, state_name: &str) -> Result<(), String> {
-        let project_item_id = issue
-            .project_item_id
-            .as_deref()
-            .ok_or("update_issue_state requires project_item_id")?;
-
-        tracing::debug!(
-            project_item_id,
-            state_name,
-            "Updating GitHub project item status"
