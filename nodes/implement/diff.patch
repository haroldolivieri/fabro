-                .await?;
-
-                user_resp["data"]["user"]["projectV2"]["id"]
-                    .as_str()
-                    .map(|s| s.to_string())
-                    .ok_or_else(|| {
-                        format!(
-                            "Project #{} not found for owner '{}'",
-                            self.project_number, self.owner
-                        )
-                    })
-            })
-            .await
-            .map(|s| s.as_str())
-    }
-}
