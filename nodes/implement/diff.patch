-    async fn fetch_issues_by_ids(&self, ids: &[&str]) -> Result<Vec<Issue>, String> {
-        if ids.is_empty() {
-            return Ok(Vec::new());
-        }
-
-        tracing::debug!(
-            count = ids.len(),
