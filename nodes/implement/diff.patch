-        );
-
-        let token = self.fresh_token().await?;
-        let project_node_id = self.resolve_project_node_id(&token).await?;
-        let graphql_url = self.graphql_url();
-
-        let id_set: std::collections::HashSet<&str> = ids.iter().copied().collect();
